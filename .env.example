# ==============================================================================
# Starter Kit — environment configuration
#
#   cp .env.example .env
#
# Then fill in the secrets marked "generate" below. Docker Compose REFUSES TO
# START if a required secret is missing — that is deliberate. There are no
# working default passwords anywhere in this repo, because a default password is
# a backdoor the moment someone deploys without reading the docs.
#
# Generate each one with:
#
#   openssl rand -hex 32
#
# Legend:  [required]  must be set, locally and in production
#          [prod]      must be set in production; the local default is fine
#          [optional]  the feature turns itself off cleanly when unset
# ==============================================================================


# --- General ------------------------------------------------------------------
NODE_ENV=development
SITE_NAME="My Site"

# [prod] Public origin of the site. In production this is ALSO the CORS allowlist
# for the API and Directus, so it must be the real https:// origin.
SITE_URL=http://localhost:3001

# Where page content comes from:
#   auto   — try the CMS, fall back to built-in demo content, and log each
#            fallback (`[content] fallback served for …`). Best for development.
#   cms    — CMS only. Empty content renders honestly empty instead of silently
#            showing demo copy. USE THIS IN PRODUCTION.
#   static — demo content only; Directus is never contacted. Good for offline
#            work, and for demoing the UI with the stack down.
CONTENT_MODE=auto


# --- Directus CMS -------------------------------------------------------------
# [required] Signs Directus session tokens. A known value here lets anyone forge
# an admin session, so there is no default. → generate
DIRECTUS_SECRET=

# [required] Admin login for the Directus UI at http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=

# [required] Database credentials. → generate the password
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=
DIRECTUS_DB_NAME=directus

# Where the BROWSER loads CMS images from — it must be reachable from the user's
# machine, so in production this is your public CMS hostname
# (e.g. https://cms.example.com), not a docker-internal name.
DIRECTUS_PUBLIC_URL=http://localhost:8055

# Where the WEB AND API SERVERS reach Directus. This differs by how you run them:
DIRECTUS_URL=http://localhost:8055    # host-run dev servers (the README quick start)
# DIRECTUS_URL=http://directus:8055   # web/api running inside docker compose

# [optional] Static Directus token for the NestJS API's /api/content routes.
# Unset, the API reads Directus as the public role — which is all the seeded
# schema grants anyway. Set it only if you lock down public read permissions.
DIRECTUS_TOKEN=


# --- Twenty CRM ---------------------------------------------------------------
# [required] Twenty's encryption secret. → generate
TWENTY_APP_SECRET=

# [required] Database credentials. → generate the password
TWENTY_DB_USER=twenty
TWENTY_DB_PASSWORD=
TWENTY_DB_NAME=twenty

TWENTY_SERVER_URL=http://localhost:3003
TWENTY_FRONT_URL=http://localhost:3003

# Same host-vs-compose choice as DIRECTUS_URL above:
TWENTY_API_URL=http://localhost:3003        # host-run dev servers
# TWENTY_API_URL=http://twenty-server:3000  # inside docker compose

# [optional] Generated in the Twenty UI after first boot (Settings → API keys).
# Unset, CRM lead creation is skipped and the contact form still notifies you.
TWENTY_API_KEY=


# --- NestJS API ---------------------------------------------------------------
API_PORT=4001

# Origins allowed to call the API, comma-separated. Never use "*" — the API is an
# internal service and only the web server should be calling it.
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# [required] Shared secret the WEB server presents to the API on every
# server-to-server call. Both sides read this same variable. → generate
INTERNAL_API_KEY=

# Where the web server reaches the API:
API_URL=http://localhost:4001    # host-run dev servers
# API_URL=http://api:4001        # inside docker compose


# --- Security -----------------------------------------------------------------
# [required] Signs the contact form's CSRF cookie. The web server REFUSES TO
# START without it: an unsigned CSRF cookie is a forgeable one. → generate
CSRF_SECRET=

# [optional in dev / REQUIRED in prod] Cloudflare Turnstile CAPTCHA.
# https://dash.cloudflare.com → Turnstile → add a site.
#
# Unset in development, the captcha check passes, so you can work without a
# Cloudflare account. Unset in PRODUCTION, submissions are REJECTED — a captcha
# that fails open is not a captcha. To run production without one on purpose,
# delete the verifyTurnstile() call in apps/web/app/routes/contact.tsx; rate
# limiting and the honeypot still apply.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# --- Email (Resend) — [optional] ----------------------------------------------
# Unset: admin email notifications are skipped and the form still works.
# https://resend.com → API keys. The from-address domain must be verified there.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@example.com
ADMIN_NOTIFICATION_EMAIL=admin@example.com


# --- Discord notifications — [optional] ---------------------------------------
# Unset: Discord alerts are skipped.
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=


# --- Analytics (Plausible) — [optional] ---------------------------------------
# Unset: no analytics, and no third-party requests at all. Both are needed.
# PLAUSIBLE_DOMAIN is the site as registered in Plausible (e.g. example.com);
# PLAUSIBLE_API_HOST is https://plausible.io, or your self-hosted instance.
PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_HOST=


# --- Error tracking (Sentry / GlitchTip) — [optional] -------------------------
# Unset: errors are logged to the console only.
# SENTRY_DSN is server-side (web SSR + API). VITE_SENTRY_DSN is compiled into the
# BROWSER bundle — it is public by design, so never put a real secret in it.
SENTRY_DSN=
VITE_SENTRY_DSN=
